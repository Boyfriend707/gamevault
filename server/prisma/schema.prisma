generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  displayName String?
  password  String
  avatarUrl String?
  decorationUrl String?
  bannerUrl String?
  bio       String?
  status    String?
  accentColor String?
  bannerCrop String?
  role      String   @default("user")
  xp        Int      @default(0)
  profileTheme String?
  loginStreak Int      @default(0)
  lastLoginDate DateTime?
  visibility   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sentRequests     FriendRequest[]  @relation("SentRequests")
  receivedRequests FriendRequest[]  @relation("ReceivedRequests")
  friendships      Friendship[]     @relation("UserFriendships")
  friendedBy       Friendship[]     @relation("FriendOf")
  games            Game[]
  tags             Tag[]
  steamLink        SteamLink?
  settings         Settings?
  conversations    ConversationParticipant[]
  messages         Message[]
  notifications    Notification[]
  sessions         PlaySession[]
  gameScreenshots  GameScreenshot[]
  gameMilestones   GameMilestone[]
  challengesCreated Challenge[] @relation("ChallengeCreator")
  challengeParticipants ChallengeParticipant[]
  badges           UserBadge[]
  createdBadges    Badge[]      @relation("CreatedBadges")
  awardedBadges    UserBadge[]  @relation("AwardedBadges")
  pollVotes        PollVote[]
  dailyProgress    DailyChallengeProgress[]
}

model Conversation {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  typing    String?

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  conversationId Int
  userId         Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@id([conversationId, userId])
}

model Message {
  id             Int      @id @default(autoincrement())
  content        String
  imageUrl       String?
  editedAt       DateTime?
  deletedAt      DateTime?
  reactions      String?
  replyToId      Int?
  createdAt      DateTime @default(now())
  conversationId Int
  userId         Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])
  replyTo        Message?    @relation("MessageReply", fields: [replyToId], references: [id])
  replies        Message[]   @relation("MessageReply")
  poll           ChatPoll?
}

model ChatPoll {
  id            Int      @id @default(autoincrement())
  messageId     Int      @unique
  question      String
  options       String   // JSON array of {id,text}
  allowMultiple Boolean  @default(false)
  closesAt      DateTime?
  createdAt     DateTime @default(now())
  message       Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  votes         PollVote[]
}

model PollVote {
  id        Int      @id @default(autoincrement())
  pollId    Int
  userId    Int
  optionId  String
  createdAt DateTime @default(now())
  poll      ChatPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  @@unique([pollId, userId, optionId])
}

model FriendRequest {
  id        Int      @id @default(autoincrement())
  status    String   @default("pending")
  createdAt DateTime @default(now())

  senderId   Int
  receiverId Int
  sender     User @relation("SentRequests", fields: [senderId], references: [id])
  receiver   User @relation("ReceivedRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

model Friendship {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  userId   Int
  friendId Int
  user     User @relation("UserFriendships", fields: [userId], references: [id])
  friend   User @relation("FriendOf", fields: [friendId], references: [id])

  @@unique([userId, friendId])
}

model Game {
  id        Int      @id @default(autoincrement())
  name      String
  platform  String
  notes     String?
  coverUrl  String?
  localPath   String?
  steamAppId  Int?
  playtime    Int      @default(0)
  status      String   @default("not-playing")
  pinned      Boolean  @default(false)
  pinOrder    Int      @default(0)
  cardColor   String?
  rating      Int?
  review      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId Int
  user   User   @relation(fields: [userId], references: [id])
  tags   GameTag[]
  sessions PlaySession[]
  servers    GameServer[]
  screenshots GameScreenshot[]
  milestones GameMilestone[]
  challenges Challenge[]
}

model Tag {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  userId Int
  user   User   @relation(fields: [userId], references: [id])
  games  GameTag[]

  @@unique([name, userId])
}

model GameTag {
  gameId Int
  tagId  Int
  game   Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([gameId, tagId])
}

model SteamLink {
  id           Int       @id @default(autoincrement())
  steamId      String    @unique
  displayName  String?
  avatarUrl    String?
  profileUrl   String?
  onlineStatus Int?      @default(0)
  syncCount    Int       @default(0)
  lastSynced   DateTime?
  createdAt    DateTime  @default(now())

  userId Int    @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Settings {
  id              Int      @id @default(autoincrement())
  theme           String   @default("light")
  unlockedThemes  String   @default("[]")
  completedGoals  String   @default("[]")
  background      String?
  shortcuts       String   @default("{\"enabled\":true,\"bindings\":{}}")
  fontSize        String   @default("normal")
  density         String   @default("normal")
  reducedMotion   Boolean  @default(false)
  bgType          String   @default("gradient")
  bgVideo         String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId Int    @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // friend_request, friend_accepted, goal_completed, new_message
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlaySession {
  id        Int      @id @default(autoincrement())
  gameId    Int
  userId    Int
  minutes   Int      @default(0)
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GameServer {
  id    Int    @id @default(autoincrement())
  gameId Int
  host  String
  port  Int
  label String?
  game  Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  @@unique([gameId, host, port])
}

model GameScreenshot {
  id        Int      @id @default(autoincrement())
  gameId    Int
  userId    Int
  url       String
  caption   String?  @default("")
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model GameMilestone {
  id        Int      @id @default(autoincrement())
  gameId    Int
  userId    Int
  title     String
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Challenge {
  id        Int      @id @default(autoincrement())
  creatorId Int
  gameId    Int
  name      String
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  creator   User     @relation("ChallengeCreator", fields: [creatorId], references: [id])
  game      Game     @relation(fields: [gameId], references: [id])
  participants ChallengeParticipant[]
}

model ChallengeParticipant {
  id          Int      @id @default(autoincrement())
  challengeId Int
  userId      Int
  playtime    Int      @default(0)
  won         Boolean  @default(false)
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id])
  @@unique([challengeId, userId])
}

model Decoration {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  fileUrl   String
  createdAt DateTime @default(now())
}

model Badge {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  iconUrl       String?
  description   String?
  isSystemBadge Boolean  @default(false)
  createdById   Int?
  createdBy     User?    @relation("CreatedBadges", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())
  users         UserBadge[]
}

model UserBadge {
  id          Int      @id @default(autoincrement())
  userId      Int
  badgeId     Int
  awardedById Int?
  awardedBy   User?    @relation("AwardedBadges", fields: [awardedById], references: [id])
  note        String?
  awardedAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  badge       Badge    @relation(fields: [badgeId], references: [id])
  @@unique([userId, badgeId])
}

model DailyChallenge {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  type        String
  requirement Int      @default(1)
  xpReward    Int      @default(50)
  date        DateTime
  createdAt   DateTime @default(now())
  progress    DailyChallengeProgress[]
  @@unique([type, date])
}

model DailyChallengeProgress {
  id               Int      @id @default(autoincrement())
  dailyChallengeId Int
  userId           Int
  progress         Int      @default(0)
  completed        Boolean  @default(false)
  dailyChallenge   DailyChallenge @relation(fields: [dailyChallengeId], references: [id], onDelete: Cascade)
  user             User           @relation(fields: [userId], references: [id])
  @@unique([dailyChallengeId, userId])
}
